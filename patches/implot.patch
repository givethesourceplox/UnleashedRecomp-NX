@@ -132,6 +132,7 @@ You can read releases logs https://github.com/epezent/implot/releases for more d
 #ifndef IMGUI_DISABLE
 #include "implot_internal.h"
 
+#include <stdint.h>
 #include <stdlib.h>
 
 // Support for pre-1.82 versions. Users on 1.82+ can use 0 (default) flags to mean "all corners" but in order to support older versions we are more explicit.
@@ -907,10 +908,26 @@ inline int GetTimeStep(int max_divs, ImPlotTimeUnit unit) {
     return 0;
 }
 
+#if defined(__SWITCH__)
+static time_t ImPlotTimeGm(struct tm* ptm) {
+    int year = ptm->tm_year + 1900;
+    const unsigned month = static_cast<unsigned>(ptm->tm_mon + 1);
+    year -= month <= 2;
+    const int era = (year >= 0 ? year : year - 399) / 400;
+    const unsigned yoe = static_cast<unsigned>(year - era * 400);
+    const unsigned doy = (153 * (month + (month > 2 ? -3 : 9)) + 2) / 5 + static_cast<unsigned>(ptm->tm_mday) - 1;
+    const unsigned doe = yoe * 365 + yoe / 4 - yoe / 100 + doy;
+    const int64_t days = static_cast<int64_t>(era) * 146097 + static_cast<int64_t>(doe) - 719468;
+    return static_cast<time_t>(days * 86400 + ptm->tm_hour * 3600 + ptm->tm_min * 60 + ptm->tm_sec);
+}
+#endif
+
 ImPlotTime MkGmtTime(struct tm *ptm) {
     ImPlotTime t;
 #ifdef _WIN32
     t.S = _mkgmtime(ptm);
+#elif defined(__SWITCH__)
+    t.S = ImPlotTimeGm(ptm);
 #else
     t.S = timegm(ptm);
 #endif
